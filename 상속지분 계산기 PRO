<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>상속지분 계산기 PRO</title>
  
  <!-- React 및 Babel 라이브러리 로드 -->
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  
  <!-- Tailwind CSS 로드 -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- 멋진 필기체 폰트 로드 (워터마크용) -->
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500;600&display=swap" rel="stylesheet">

  <style>
    /* 💡 베이스 설정: 폴더 디자인이 돋보이도록 배경색을 옅은 회색으로 변경 */
    body {
      color: #37352f;
      background-color: #f1f1ef; 
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    }

    /* 포커스 시 노션 특유의 블루 링 */
    input:focus, select:focus, button:focus {
      outline: none;
      box-shadow: 0 0 0 2px rgba(35, 131, 226, 0.3);
      border-color: #2383e2 !important;
    }
    
    /* 인풋 그룹 포커스 효과 */
    .input-combo:focus-within {
      border-color: #2383e2 !important;
      box-shadow: 0 0 0 2px rgba(35, 131, 226, 0.3);
    }

    .designer-sign {
      font-family: 'Dancing Script', cursive;
      font-size: 16px;
      color: #d4d4d4;
      font-weight: 600;
      letter-spacing: 0.5px;
      margin-left: 8px;
    }

    /* 커스텀 스크롤바 */
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #d3d1cb; border-radius: 5px; border: 2px solid white; }
    ::-webkit-scrollbar-thumb:hover { background: #aeaca6; }

    /* 💡 브라우저 인쇄 레이아웃 최적화 (상30 하20 좌우25) */
    @media print {
      body { 
        background-color: white !important; 
        -webkit-print-color-adjust: exact; 
        print-color-adjust: exact; 
        font-size: 11pt !important;
        color: #000000 !important;
      }
      
      @page { margin: 30mm 25mm 20mm 25mm; }
      
      .no-print { display: none !important; }
      .print-compact { padding: 0 !important; margin: 0 !important; }
      .print-p-0 { padding: 0 !important; }
      
      table { page-break-inside: auto; width: 100% !important; border-collapse: collapse; }
      tr { page-break-inside: avoid; page-break-after: auto; }
      thead { display: table-header-group; }
      tfoot { display: table-footer-group; }
      
      .print-table th, .print-table td { border-bottom: 1px solid #d4d4d4 !important; }
      .print-table-top { border-top: 2px solid #37352f !important; border-bottom: 1px solid #37352f !important; }
      
      .break-inside-avoid { break-inside: avoid; page-break-inside: avoid; }
      .shadow-sm, .shadow-md, .shadow-lg, .shadow-inner { box-shadow: none !important; }

      #print-footer {
        position: fixed; bottom: 0; right: 0;
        font-family: 'Dancing Script', cursive; font-size: 14pt;
        color: #d4d4d4; text-align: right; display: block !important;
      }
    }
  </style>
</head>
<body class="min-w-[1200px] print:min-w-0">
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect } = React;
    const { flushSync } = ReactDOM; 

    // --- 아이콘 세트 ---
    const IconCalculator = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><path d="M16 10h.01M12 10h.01M8 10h.01M12 14h.01M8 14h.01M12 18h.01M8 18h.01"/></svg>;
    const IconUserPlus = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>;
    const IconTrash2 = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>;
    const IconChevronRight = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="m9 18 6-6-6-6"/></svg>;
    const IconSave = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>;
    const IconFolderOpen = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="m6 14 1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.55 6a2 2 0 0 1-1.94 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H18a2 2 0 0 1 2 2v2"/></svg>;
    const IconPrinter = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>;
    const IconCalendarDays = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>;
    const IconNetwork = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg>;
    const IconTable = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0H5a2 2 0 0 1-2-2V9m6 12h10a2 2 0 0 0 2-2V9m-18 0h20"/></svg>;
    const IconList = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>;
    const IconReset = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>;
    const IconFileText = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>;
    const IconXCircle = ({className}) => <svg className={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth="1.5"><circle cx="12" cy="12" r="10"/><path strokeLinecap="round" strokeLinejoin="round" d="m15 9-6 6m0-6 6 6"/></svg>;

    // --- 수학 및 법률 엔진 ---
    const math = {
      gcd: (a, b) => {
        a = Math.abs(Math.round(a)); b = Math.abs(Math.round(b));
        if (b === 0) return a; return math.gcd(b, a % b);
      },
      lcm: (a, b) => {
        if (a === 0 || b === 0) return 0;
        return (a / math.gcd(a, b)) * b;
      },
      simplify: (n, d) => {
        if (n === 0) return [0, 1];
        const nInt = Math.round(n); const dInt = Math.round(d);
        const g = math.gcd(Math.abs(nInt), Math.abs(dInt));
        return [nInt / g, dInt / g];
      },
      multiply: (n1, d1, n2, d2) => math.simplify(n1 * n2, d1 * d2),
      add: (n1, d1, n2, d2) => {
        if (n1 === 0) return [n2, d2];
        if (n2 === 0) return [n1, d1];
        const commonD = d1 * d2;
        const newN = (n1 * d2) + (n2 * d1);
        return math.simplify(newN, commonD);
      }
    };

    const relStr = { 'wife': '처', 'husband': '남편', 'son': '아들', 'daughter': '딸', 'sibling': '형제자매' };

    const getLawEra = (deathDate) => {
      if (!deathDate || deathDate.length < 4) return '1991';
      const year = parseInt(deathDate.split('-')[0], 10);
      if (year < 1979) return '1960';
      if (year < 1991) return '1979';
      return '1991';
    };

    const isBefore = (d1, d2) => {
      if (!d1 || !d2 || d1.length < 10 || d2.length < 10) return false;
      return new Date(d1) < new Date(d2);
    };

    const formatKorDate = (dStr) => {
      if (!dStr || dStr.length !== 10) return dStr;
      const [y, m, d] = dStr.split('-');
      return `${y}년 ${parseInt(m, 10)}월 ${parseInt(d, 10)}일`;
    };

    // 💡 숫자에 천 단위 콤마를 찍어주는 포맷터 함수
    const formatMoney = (val) => {
      if (!val) return '';
      return Number(val).toLocaleString('ko-KR');
    };

    // --- 컴포넌트: 날짜 입력 ---
    const DateInput = ({ value, onChange, placeholder, className, onKeyDown }) => {
      const format = (v) => {
        let val = v.replace(/\D/g, '').slice(0, 8);
        if (val.length > 6) return `${val.slice(0, 4)}-${val.slice(4, 6)}-${val.slice(6, 8)}`;
        if (val.length > 4) return `${val.slice(0, 4)}-${val.slice(4)}`;
        return val;
      };
      return <input type="text" value={value || ''} onKeyDown={onKeyDown} onChange={e => onChange(format(e.target.value))} onFocus={e => e.target.select()} placeholder={placeholder || "YYYY-MM-DD"} className={className} />;
    };

    // 💡 부드러운 파스텔 녹색 -> 파란색 -> 보라색 -> 핑크색 그라데이션 확장 적용 (계층 구분)
    const getLevelStyle = (level) => {
      if (level === 1) return "bg-[#f0fdf4] border-[#bbf7d0]"; // 1차: 연녹색 (Green)
      if (level === 2) return "bg-[#ecfeff] border-[#a5f3fc]"; // 2차: 연청록 (Cyan)
      if (level === 3) return "bg-[#eff6ff] border-[#bfdbfe]"; // 3차: 연파랑 (Blue)
      if (level === 4) return "bg-[#eef2ff] border-[#c7d2fe]"; // 4차: 연남색 (Indigo)
      if (level === 5) return "bg-[#faf5ff] border-[#e9d5ff]"; // 5차: 연보라 (Purple)
      if (level === 6) return "bg-[#fdf4ff] border-[#fbcfe8]"; // 6차: 연분홍 (Fuchsia)
      return "bg-[#fff1f2] border-[#fecdd3]";                  // 7차 이상: 연장미 (Rose)
    };

    // 💡 계층 깊이에 따른 연결선 색상 지정 (5~6단계 이상 확장)
    const getLineStyle = (level) => {
      if (level === 2) return "border-[#22d3ee]"; // 2차 연결선: 청록색
      if (level === 3) return "border-[#60a5fa]"; // 3차 연결선: 파란색
      if (level === 4) return "border-[#818cf8]"; // 4차 연결선: 남색
      if (level === 5) return "border-[#a855f7]"; // 5차 연결선: 보라색
      if (level === 6) return "border-[#e879f9]"; // 6차 연결선: 분홍색
      return "border-[#fb7185]";                  // 7차 이상 연결선: 장미색
    };

    // --- 상속인 입력 블록 ---
    const HeirRow = ({ node, level, handleUpdate, removeHeir, addHeir, siblings, inheritedDate, onKeyDown, toggleSignal }) => {
      const isSp = node.relation === 'wife' || node.relation === 'husband';
      const isSon = node.relation === 'son';
      const isDaughter = node.relation === 'daughter';
      const canAutoFill = node.isDeceased && isSp && (!node.heirs || node.heirs.length === 0) && siblings?.length > 0;

      // 💡 접기/펼치기 상태 추가
      const [isExpanded, setIsExpanded] = useState(true);

      // 💡 상위 컴포넌트(App)에서 보내는 모두 펼치기/접기 신호 감지
      useEffect(() => {
        if (toggleSignal > 0) setIsExpanded(true);
        else if (toggleSignal < 0) setIsExpanded(false);
      }, [toggleSignal]);

      // 💡 상속 개시일에 따른 법령 판단 (1991년 이후면 호주상속, 동일가적 옵션 숨김)
      const lawEra = getLawEra(inheritedDate);
      const showHoju = isSon && lawEra !== '1991';
      const showMarriedDaughter = isDaughter && lawEra !== '1991';

      // 💡 형제 중 이미 호주상속을 받은 사람이 있는지 확인
      const hasOtherHoju = siblings?.some(s => s.id !== node.id && s.isHoju);

      // 💡 하위 상속인(대습/순차)에게 물려줄 기준 상속 개시일 계산
      let nextInheritedDate = inheritedDate;
      if (node.isDeceased && node.deathDate && !isBefore(node.deathDate, inheritedDate)) {
        nextInheritedDate = node.deathDate;
      }

      const autoFill = () => {
        const children = siblings.filter(s => s.relation === 'son' || s.relation === 'daughter');
        const clone = (n) => ({ ...n, id: `auto_${Math.random().toString(36).substr(2,9)}`, heirs: n.heirs?.map(clone) || [] });
        handleUpdate(node.id, 'heirs', children.map(clone));
      };

      const boxStyle = getLevelStyle(level);
      const lineStyle = getLineStyle(level);

      return (
        <div className={`mt-2 ${level > 1 ? `ml-8 pl-4 border-l-[3px] ${lineStyle}` : ''}`}>
          <div className={`${boxStyle} border rounded-md p-2.5 hover:shadow-sm transition-colors relative nav-row no-print group flex items-center`}>
            
            {/* 💡 기존 삭제 버튼 자리에 펼치기/접기 버튼 배치 (사망 시에만 표시) */}
            <div className="w-7 flex justify-center shrink-0 mr-1">
              {node.isDeceased && (
                <button type="button" onClick={() => setIsExpanded(!isExpanded)} className="text-[#787774] hover:bg-black/5 p-1 rounded transition-colors" title={isExpanded ? "접기" : "펼치기"}>
                  <IconChevronRight className={`w-5 h-5 transition-transform ${isExpanded ? 'rotate-90' : ''}`} />
                </button>
              )}
            </div>

            {/* 입력 항목 가로 밀착 배치 (글씨 크기 및 패딩 일관성 정돈) */}
            <div className="flex items-center gap-2 flex-nowrap w-full">
              
              {/* 성명 */}
              <div className="flex items-center bg-white border border-[#cccccc] rounded overflow-hidden input-combo">
                <span className="bg-[#f1f1ef] text-[#504f4c] font-semibold px-3 py-1.5 text-[13px] border-r border-[#cccccc]">성명</span>
                <input type="text" placeholder="성명" value={node.name} onKeyDown={onKeyDown} onChange={e => handleUpdate(node.id, 'name', e.target.value)} onFocus={e => e.target.select()} 
                  className="w-24 px-3 py-1.5 text-[14px] font-bold text-[#0b6e99] outline-none" />
              </div>
              
              {/* 관계 */}
              <div className="flex items-center bg-white border border-[#cccccc] rounded overflow-hidden relative input-combo">
                <span className="bg-[#f1f1ef] text-[#504f4c] font-semibold px-3 py-1.5 text-[13px] border-r border-[#cccccc]">관계</span>
                <select value={node.relation} onKeyDown={onKeyDown} onChange={e => handleUpdate(node.id, 'relation', e.target.value)} 
                  className="w-24 px-3 py-1.5 text-[14px] font-semibold text-[#37352f] bg-white outline-none cursor-pointer appearance-none">
                  <option value="wife">처</option><option value="husband">남편</option><option value="son">아들</option><option value="daughter">딸</option><option value="sibling">형제자매</option>
                </select>
                <div className="pointer-events-none absolute inset-y-0 right-2 flex items-center text-[#787774]"><IconChevronRight className="w-4 h-4 rotate-90" /></div>
              </div>

              {/* 호주 / 동일가적 옵션 */}
              <div className="flex items-center gap-2 pl-1">
                {showHoju && (
                  <label className={`flex items-center gap-1.5 px-3 py-1.5 rounded border transition-colors select-none ${
                    node.isHoju 
                      ? 'bg-[#fce7f3] border-[#fbcfe8] text-[#be185d] cursor-pointer' 
                      : hasOtherHoju 
                        ? 'bg-[#f1f1ef] border-[#e9e9e7] text-[#a3a3a3] cursor-not-allowed opacity-70' 
                        : 'bg-white border-[#cccccc] hover:bg-[#f1f1ef] text-[#787774] cursor-pointer'
                  }`}>
                    <input 
                      type="checkbox" 
                      checked={node.isHoju || false} 
                      disabled={hasOtherHoju && !node.isHoju}
                      onKeyDown={onKeyDown} 
                      onChange={e => handleUpdate(node.id, 'isHoju', e.target.checked)} 
                      className={`w-3.5 h-3.5 accent-[#be185d] ${hasOtherHoju && !node.isHoju ? 'cursor-not-allowed grayscale' : 'cursor-pointer'}`} 
                    />
                    <span className="text-[13px] font-bold">호주상속</span>
                  </label>
                )}
                
                {showMarriedDaughter && (
                  <label className={`flex items-center gap-1.5 px-3 py-1.5 rounded border transition-colors cursor-pointer select-none ${node.isSameRegister !== false ? 'bg-[#f3f0ff] border-[#d9cfff] text-[#402c84]' : 'bg-white border-[#cccccc] hover:bg-[#f1f1ef] text-[#787774]'}`}>
                    <input type="checkbox" checked={node.isSameRegister !== false} onKeyDown={onKeyDown} onChange={e => handleUpdate(node.id, 'isSameRegister', e.target.checked)} className="w-3.5 h-3.5 cursor-pointer accent-[#402c84]" />
                    <span className="text-[13px] font-bold">동일가적</span>
                  </label>
                )}

                {showMarriedDaughter && node.isSameRegister === false && (
                  <div className="flex items-center bg-white border border-[#cccccc] rounded overflow-hidden input-combo ml-1">
                    <span className="bg-[#ffedd5] text-[#c2410c] font-semibold px-3 py-1.5 text-[13px] border-r border-[#fed7aa]">혼인일</span>
                    <DateInput value={node.marriageDate} onKeyDown={onKeyDown} onChange={v => handleUpdate(node.id, 'marriageDate', v)} className="w-28 px-3 py-1.5 text-[14px] font-semibold outline-none text-[#37352f]" />
                  </div>
                )}
              </div>

              {/* 💡 눈 아프지 않은 옅은 사망 버튼 (크기 통일) */}
              <label className={`flex items-center gap-1.5 px-3 py-1.5 rounded border cursor-pointer transition-colors ml-auto select-none ${node.isDeceased ? 'bg-[#ffe2dd] border-[#f0c0b9] text-[#c93f3a]' : 'bg-white border-[#cccccc] text-[#787774] hover:bg-[#f1f1ef]'}`}>
                <input type="checkbox" checked={node.isDeceased || false} onKeyDown={onKeyDown} onChange={e => handleUpdate(node.id, 'isDeceased', e.target.checked)} className="w-4 h-4 cursor-pointer accent-[#c93f3a]" />
                <span className="text-[13px] font-bold">사망</span>
              </label>

              {node.isDeceased && (
                <div className="flex items-center bg-white border border-[#f0c0b9] rounded overflow-hidden input-combo">
                  <span className="bg-[#ffe2dd] text-[#c93f3a] font-semibold px-3 py-1.5 text-[13px] border-r border-[#f0c0b9]">사망일</span>
                  <DateInput value={node.deathDate} onKeyDown={onKeyDown} onChange={v => handleUpdate(node.id, 'deathDate', v)} className="w-28 px-3 py-1.5 text-[14px] font-semibold outline-none text-[#37352f]" />
                </div>
              )}

              {isSp && level > 1 && (
                <label className={`flex items-center gap-1.5 px-3 py-1.5 rounded border transition-colors cursor-pointer select-none ${node.isRemarried ? 'bg-[#e3e2e0] border-[#d4d4d4] text-[#37352f]' : 'bg-white border-[#cccccc] hover:bg-[#f1f1ef] text-[#787774]'}`}>
